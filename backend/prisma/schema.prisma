generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  avatar   String?
  answers  Answer[] @relation("UserFrom")
}

model Group {
  id         Int              @id @default(autoincrement())
  name       String
  inviteCode String           @unique
  answers    Answer[]
  daily      DailyQuestion[]
}

model Question {
  id             Int      @id @default(autoincrement())
  text           String
  type           String   @default("random")
  tipoSeleccion  String   @default("multiple")
  answers        Answer[]
  daily          DailyQuestion[]
}

model Answer {
  id           Int       @id @default(autoincrement())
  questionId   Int
  userFromId   Int
  userTargetId Int?
  groupId      Int
  answerText   String
  date         DateTime  @default(now())
  isAnonymous  Boolean   @default(false)

  question     Question  @relation(fields: [questionId], references: [id])
  userFrom     User      @relation("UserFrom", fields: [userFromId], references: [id])
  group        Group     @relation(fields: [groupId], references: [id])
}

model DailyQuestion {
  id         Int      @id @default(autoincrement())
  questionId Int
  groupId    Int
  date       DateTime @default(now())

  question   Question @relation(fields: [questionId], references: [id])
  group      Group    @relation(fields: [groupId], references: [id])

  @@unique([groupId, date])
}
